---
import Base from '../../layouts/Base.astro';
import BlockRenderer from '../../components/BlockRenderer.astro';
import { getPosts, getPostBySlug } from '../../lib/api';

export async function getStaticPaths() {
  const { items: posts } = await getPosts(100).catch(() => ({ items: [] }));
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/404');
}
---

<Base title={post.title}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4">{post.title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <time datetime={post.publishedAt || post.createdAt}>
          {new Date(post.publishedAt || post.createdAt).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {post.categories && post.categories.length > 0 && (
          <span>
            in{' '}
            {post.categories.map((cat, i) => (
              <>
                <a href={`/blog/category/${cat.slug}`} class="hover:text-blue-600">
                  {cat.name}
                </a>
                {i < post.categories!.length - 1 && ', '}
              </>
            ))}
          </span>
        )}
      </div>
      {post.tags && post.tags.length > 0 && (
        <div class="flex gap-2 mt-4">
          {post.tags.map((tag) => (
            <a
              href={`/blog/tag/${tag.slug}`}
              class="text-xs px-2 py-1 bg-gray-100 rounded-full hover:bg-gray-200"
            >
              #{tag.name}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none">
      <BlockRenderer blocks={post.blocks} />
    </div>

    <footer class="mt-12 pt-8 border-t border-gray-200">
      <a href="/blog" class="text-blue-600 hover:underline">← Back to blog</a>
    </footer>
  </article>
</Base>
