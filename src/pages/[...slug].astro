---
import Base from '../layouts/Base.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { getPages, getPageBySlug } from '../lib/api';

export async function getStaticPaths() {
  const pages = await getPages().catch(() => []);
  return pages
    .filter((page) => page.slug !== 'home') // Home is handled by index
    .map((page) => ({
      params: { slug: page.slug },
    }));
}

const { slug } = Astro.params;
const page = await getPageBySlug(slug as string);

if (!page) {
  return Astro.redirect('/404');
}
---

<Base title={page.title}>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">{page.title}</h1>
    <BlockRenderer blocks={page.blocks} />
  </div>
</Base>
